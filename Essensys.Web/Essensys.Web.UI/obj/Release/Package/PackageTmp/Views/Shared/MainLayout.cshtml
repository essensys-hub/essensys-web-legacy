<!DOCTYPE html>

<html lang="fr">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link href="~/favicon.ico" rel="shortcut icon" type="image/x-icon" />
    <title>Essensys - @ViewBag.Title</title>
    @Styles.Render("~/Content/Essensys.css")
    @Scripts.Render("~/bundles/modernizr")
        
    @Scripts.Render("~/bundles/jquery")
    @RenderSection("scripts", required: false)

    @RenderSection("head", required: false)
</head>
<body>
    <div class='es-blk-main'>
        <header>
            <img src="/Content/images/logosml.png" width="132px" height="40px" alt="Essensys" title="Essensys" />
            <ul class='es-option'>
                <li><a href='/Account/UpdateMyInfos'>Modifier mes informations personnelles</a></li>                    
            </ul>
        </header>
        <section>
            @RenderBody()
        </section>
    </div>
</body>
</html>
