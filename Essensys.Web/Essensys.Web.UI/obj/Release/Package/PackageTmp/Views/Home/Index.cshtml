    <span>Changement de paramètre à valider</span>
    <div class='esys-validinfo'>
        <h3>Chauffage Zone Jour</h3>
        <div class='clear'>
            @Html.Label("auto", "Automatique (planning)")
            @Html.RadioButton("chauffagezj", "0", false)
        </div>
        <div class='clear'>
            @Html.Label("anticipe", "Anticipé")
            @Html.RadioButton("chauffagezj", "32", false)
        </div>
        <div class='clear'>
            @Html.Label("confort", "Forçage confort")
            @Html.RadioButton("chauffagezj", "16", false)
        </div>
        <div class='clear'>
            @Html.Label("eco", "Forçage éco")
            @Html.RadioButton("chauffagezj", "17", false)
        </div>
        <div class='clear'>
            @Html.Label("eco+", "Forçage éco+")
            @Html.RadioButton("chauffagezj", "18", false)
        </div>
        <div class='clear'>
            @Html.Label("eco++", "Forçage éco++")
            @Html.RadioButton("chauffagezj", "19", false)
        </div>
        <div class='clear'>
            @Html.Label("hgel", "Forçage hors gel")
            @Html.RadioButton("chauffagezj", "20", false)
        </div>
        <div class='clear'>
            @Html.Label("off", "OFF")
