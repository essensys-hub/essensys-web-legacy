<?xml version="1.0" encoding="utf-8" ?>
<!-- 
    Remarque : Ajoutez des entrées au fichier App.config pour les paramètres de configuration
    qui s'appliquent uniquement au projet Test.
-->
<configuration>
    <appSettings>
		<add key="OCTOPUSH_LOGIN" value="YOUR_OCTOPUSH_LOGIN"/>
		<add key="OCTOPUSH_APIKEY" value="YOUR_OCTOPUSH_APIKEY"/>
		<add key="OCTOPUSH_MODE" value="real"/>
		<add key="mailserver" value="ns0.ovh.net"/>
		<add key="mailport" value="587"/>
		<add key="mailuser" value="YOUR_SMTP_USER"/>
		<add key="mailpassword" value="YOUR_SMTP_PASSWORD"/>
		<add key="mailreplyto" value="YOUR_SMTP_USER"/>
		<add key="webserver" value="http://localhost:26692"/>
		<add key="waitessensysbox" value="false"/>
    </appSettings>

	<connectionStrings>
		<add name="Essensys" connectionString="Integrated Security=SSPI;Initial Catalog=ESSENSYS;Data Source=(LOCAL)\EBZDB"/>
	</connectionStrings>
</configuration>
