{
  "mcpServers": {
    "github-essensys": {
      "command": "uvx",
      "args": ["mcp-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_PAT_HERE",
        "GITHUB_ORGANIZATION": "essensys-hub"
      },
      "disabled": false,
      "autoApprove": []
    }
  },
  "powers": {
    "mcpServers": {}
  }
}
