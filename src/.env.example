# Configuration Essensys Backend

# Environnement
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3000

# Base de données PostgreSQL
DATABASE_URL="postgresql://username:password@localhost:5432/essensys_db"
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=essensys_db
DATABASE_USER=username
DATABASE_PASSWORD=password
DATABASE_SSL=false

# Redis (pour les sessions et cache)
REDIS_URL="redis://localhost:6379"
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Machine JWT (pour les boîtiers IoT)
MACHINE_JWT_SECRET=your-super-secret-machine-key-change-in-production
MACHINE_JWT_EXPIRY=24h

# Logging
LOG_LEVEL=info

# Email Configuration (pour les notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@essensys.com

# SMS Configuration (Octopush ou autre)
SMS_PROVIDER=octopush
SMS_API_KEY=your-sms-api-key
SMS_API_SECRET=your-sms-api-secret

# Sécurité
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Timezone
TZ=Europe/Paris